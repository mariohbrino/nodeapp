{
  "name": "nodeapp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "node web application example",
  "main": "index.ts",
  "engines": {
    "node": ">=22.22.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "node src/index.ts",
    "build": "tsc --rootDir ./src --outDir ./dist",
    "start": "node dist/index.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:units": "vitest run --reporter=verbose --project=unit-tests --coverage",
    "test:features": "vitest run --reporter=verbose --project=feature-tests --coverage",
    "test:dev": "vitest watch",
    "test:coverage": "vitest run --reporter=verbose --coverage"
  },
  "author": "Mario Brino",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
