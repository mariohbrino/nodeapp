{
  "name": "nodeapp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "node web application example",
  "main": "app.ts",
  "engines": {
    "node": ">=22.22.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "tsx --watch src/app.ts",
    "prebuild": "prisma generate",
    "build": "tsc --project tsconfig.build.json",
    "schema:generate": "prisma generate",
    "db": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "start": "tsx dist/app.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:units": "vitest run --reporter=verbose --project=unit-tests --coverage",
    "test:features": "vitest run --reporter=verbose --project=feature-tests --coverage",
    "test:integrations": "vitest run --reporter=verbose --project=integration-tests --coverage",
    "test:dev": "vitest watch --reporter=verbose",
    "test:coverage": "vitest run --reporter=verbose --coverage"
  },
  "author": "Mario Brino",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
