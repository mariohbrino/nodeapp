<div class="bg-gray-800 w-full max-w-4xl mx-auto p-6 rounded-2xl">
  <h1 class="text-2xl font-bold mb-4">{{title}}</h1>
  <section>
    {{#each posts.data}}
      <div class="bg-gray-200 text-gray-800 my-4 p-4 rounded">
        <h2 class="text-xl font-semibold">
          <a class="text-green-600 hover:text-green-400" href="/posts/{{this.id}}">{{this.title}}</a>
        </h2>
        <p class="text-gray-500">
          Created by
          <a class="text-green-600 hover:text-green-400" href="/users/{{this.author.id}}">{{this.author.name}}</a>
          on {{formatDate this.createdAt}}
        </p>
      </div>
    {{/each}}
    <p>Total Posts: {{posts.total}}</p>
  </section>
</div>
